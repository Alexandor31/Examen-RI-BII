# Never commit real credentials. Copy this file to .env for local development.
LLM_API_KEY=
LLM_API_BASE=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# Retrieval
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
ENABLE_RERANKER=true
RETRIEVAL_CANDIDATES=20
TOP_K=5
MIN_SEMANTIC_SCORE=0.20
MIN_RERANK_SCORE=0.05

# Corpus and persistence
DATA_DIR=./data
CHROMA_DIR=./data/chroma
CHROMA_COLLECTION=arxiv_abstracts
CHUNK_SIZE=1800
CHUNK_OVERLAP=250

# Set true for cloud startup. Leave MAX_DOCUMENTS empty to index the full corpus.
AUTO_BUILD_INDEX=false
MAX_DOCUMENTS=
